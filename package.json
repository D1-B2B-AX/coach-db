{
  "name": "coach-db",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "prisma migrate deploy && next start -p ${PORT:-3000}",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "seed": "npx tsx scripts/seed-master-data.ts",
    "migrate:coaches": "npx tsx scripts/migrate-coaches.ts",
    "db:migrate": "prisma migrate deploy",
    "db:push": "node -e \"if(process.env.DATABASE_URL?.includes('proxy.rlwy.net')){console.error('\\x1b[31m프로덕션 DB에는 db push를 사용할 수 없습니다. prisma migrate deploy를 사용하세요.\\x1b[0m');process.exit(1)}\" && prisma db push"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-s3": "^3.1014.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@sentry/nextjs": "^10.46.0",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "nodemailer": "^7.0.13",
    "pg": "^8.20.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "web-push": "^3.6.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@notionhq/client": "^5.14.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "googleapis": "^171.4.0",
    "prisma": "^7.5.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^3.2.1"
  }
}
